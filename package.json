{
  "name": "activity-by-securaity",
  "version": "0.2.0",
  "description": "See what your AI agents are doing — in plain English",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "npx esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/server.js --external:better-sqlite3",
    "start": "electron .",
    "package": "npm run build && npx electron-builder --mac --arm64",
    "package:intel": "npm run build && npx electron-builder --mac --x64",
    "package:all": "npm run build && npx electron-builder --mac --universal",
    "publish": "npm run build && npx electron-builder --mac --arm64 --publish always",
    "docker:build": "docker build -t activity-by-securaity .",
    "docker:run": "docker run -p 3400:3400 activity-by-securaity",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.securaity.activity",
    "productName": "Activity by SecurAIty",
    "directories": {
      "output": "build"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "dist/**/*",
      "node_modules/better-sqlite3/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["icon.*"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Activity by SecurAIty",
      "iconSize": 80,
      "contents": [
        { "x": 170, "y": 200 },
        { "x": 420, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "SecurAIty-AI",
      "repo": "activity",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
