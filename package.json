{
  "name": "activity-by-securaity",
  "version": "0.1.0",
  "description": "See what your AI agents are doing — in plain English",

  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "npx esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/server.js",
    "docker:build": "docker build -t activity-by-securaity .",
    "docker:run": "docker run -p 3400:3400 activity-by-securaity",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "electron": "^41.1.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
